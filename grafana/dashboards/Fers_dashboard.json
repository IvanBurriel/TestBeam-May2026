        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB-CLEAN}"
          },
          "query": "from(bucket: \"Fers_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) =>\n    r._measurement == \"fers_hits\" and\n    r._field == \"HG\" and\n    r.run == \"${run}\" and\n    r.board == \"${board}\" and\n    r.channel =~ /^${channel:regex}$/ and\n    (r.dtype == \"0x03\" or r.dtype == \"0x33\")\n  )\n  |> map(fn: (r) => ({\n      r with\n      dtype_label:\n        if r.dtype == \"0x03\" then \"0x03\"\n        else if r.dtype == \"0x33\" then \"0x33\"\n        else \"Other\"\n  }))\n  |> group(columns: [\"dtype_label\"])\n  |> count()\n",
          "refId": "A"
        }
      ],
      "title": "Pie events counter (Board ${board})",
      "type": "piechart"
