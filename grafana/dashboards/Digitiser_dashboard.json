                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"Digitiser_bucket_abs\")\n  |> range(start: 0)\n  |> filter(fn: (r) =>\n    r.run == \"${run}\" and\n    r.acq_id == \"${acq_id}\" and\n    r.channel == \"${channel}\" and\n    r.event =~ /^${event:regex}$/ and\n    (r._field == \"ADC\" or r._field == \"sample\")\n  )\n  |> pivot(\n      rowKey: [\"_time\", \"event\"],\n      columnKey: [\"_field\"],\n      valueColumn: \"_value\"\n  )\n  |> group(columns: [])\n"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
